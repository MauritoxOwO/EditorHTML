<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control namespace="EditorHTMLPBOC" 
          constructor="EditorHTML2"
          version="0.0.3" 
          display-name-key="EditorHTMLv0.3"
          description-key="EditorHTML v0.3 for testing" 
          control-type="standard" 
  >

    <external-service-usage enabled="false">
    </external-service-usage>

    <property name="htmlContent" 
              display-name-key="HTML Content" 
              description-key="HTML Content" 
              of-type="SingleLine.Text" 
              usage="bound" 
              required="false" 
    />
    <property name="entityName"
              display-name-key="HTML Dev Test" 
              description-key="HTML Dev Test" 
              of-type="SingleLine.Text" 
              usage="bound" 
              required="true"
    />

    <property name="fieldName"
              display-name-key="HTML File" 
              description-key="HTML File" 
              of-type="SingleLine.Text" 
              usage="bound" 
              required="true"
    />

    <property name="styleEntitySetName"
              display-name-key="Paragraph Style Table"
              description-key="Dataverse entity set name that stores paragraph styles"
              of-type="SingleLine.Text"
              usage="input"
              required="false"
    />

    <property name="styleClassField"
              display-name-key="Style Class Field"
              description-key="Dataverse field that stores the CSS class name"
              of-type="SingleLine.Text"
              usage="input"
              required="false"
    />

    <property name="styleCssField"
              display-name-key="Style CSS Field"
              description-key="Dataverse field that stores the CSS rule or declarations"
              of-type="SingleLine.Text"
              usage="input"
              required="false"
    />

    <resources>
      <code path="index.ts" order="1"/>
      <css path="css/editor.css" order="1"/>
    </resources>
  </control>
</manifest>